@page "/Account/Manage/Clients"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using ShadowVPN2.Data
@using ShadowVPN2.Entities.Proxy
@using ShadowVPN2.Infrastructure.Authentication

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager
@inject VpnClientService VpnClientService

<PageTitle>VPN Clients</PageTitle>

<h3>VPN Clients</h3>
<StatusMessage/>

@if (clients is { Count: > 0 })
{
    <table class="table">
        <thead>
        <tr>
            <th>Name</th>
            <th>IP Address</th>
            <th>Status</th>
            <th>Created</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var client in clients)
        {
            <tr>
                <td>@client.Name</td>
                <td><code>@client.GetAssignedIp()</code></td>
                <td>
                    @if (client.IsEnabled)
                    {
                        <span class="badge bg-success">Enabled</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Disabled</span>
                    }
                </td>
                <td>@client.CreatedAt.LocalDateTime.ToString("g")</td>
                <td>
                    <form @formname="@($"delete-client-{client.Id.Replace("/", "-")}")" @onsubmit="DeleteClient" method="post">
                        <AntiforgeryToken/>
                        <input type="hidden" name="ClientId" value="@client.Id"/>
                        <button type="submit" class="btn btn-sm btn-danger" title="Delete this client">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No VPN clients configured yet.</p>
}

<hr/>
<h4>Add a new client</h4>
<div class="row">
    <div class="col-xl-6">
        <EditForm Model="Input" FormName="add-client" OnValidSubmit="AddClient" method="post">
            <DataAnnotationsValidator/>
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.Name" id="Input.Name" class="form-control" placeholder="My iPhone"/>
                <label for="Input.Name" class="form-label">Device name</label>
                <ValidationMessage For="() => Input.Name" class="text-danger"/>
            </div>
            <div class="form-floating mb-3">
                <InputNumber @bind-Value="Input.WireGuardMtu" id="Input.WireGuardMtu" class="form-control" placeholder="1420"/>
                <label for="Input.WireGuardMtu" class="form-label">WireGuard MTU override (leave empty for default)</label>
                <ValidationMessage For="() => Input.WireGuardMtu" class="text-danger"/>
            </div>
            <button type="submit" class="btn btn-primary">Add client</button>
        </EditForm>
    </div>
</div>

@code {
    private ApplicationUser? user;
    private IReadOnlyList<EntityVpnClient>? clients;

    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm(FormName = "add-client")]
    private InputModel Input { get; set; } = default!;

    [SupplyParameterFromForm] private string? ClientId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();

        user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        clients = await VpnClientService.GetClientsAsync(user);
    }

    private async Task AddClient()
    {
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        WireGuardClientSettings? wg = Input.WireGuardMtu.HasValue
            ? new WireGuardClientSettings { Mtu = Input.WireGuardMtu.Value }
            : null;

        await VpnClientService.AddClientAsync(user, Input.Name, wg);
        RedirectManager.RedirectToCurrentPageWithStatus("Client added successfully.", HttpContext);
    }

    private async Task DeleteClient()
    {
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        if (!string.IsNullOrEmpty(ClientId))
            await VpnClientService.DeleteClientAsync(ClientId, user.Id!);

        RedirectManager.RedirectToCurrentPageWithStatus("Client deleted.", HttpContext);
    }

    private sealed class InputModel
    {
        [Required]
        [StringLength(100, MinimumLength = 1)]
        [Display(Name = "Device name")]
        public string Name { get; set; } = string.Empty;

        [Range(576, 9000)]
        [Display(Name = "WireGuard MTU")]
        public int? WireGuardMtu { get; set; }
    }
}
