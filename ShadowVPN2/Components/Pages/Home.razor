@page "/"
@using ShadowVPN2.Data
@implements IDisposable
@inject NodeService NodeService
@rendermode InteractiveServer

<PageTitle>Nodes - ShadowVPN2</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Nodes</h1>
        <span class="badge bg-primary">Live</span>
    </div>

    @if (_nodes == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!_nodes.Any())
    {
        <div class="alert alert-info" role="alert">
            No nodes found. Go to <a href="/setup">Setup</a> to add your first node.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                <tr>
                    <th scope="col" style="width: 50px;">#</th>
                    <th scope="col">Name</th>
                    <th scope="col">Address</th>
                    <th scope="col">Node ID</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var node in _nodes)
                {
                    <tr>
                        <td>@node.Number</td>
                        <td>
                            <strong>@node.Name</strong>
                        </td>
                        <td>
                            <code>@node.Address</code>
                        </td>
                        <td>
                            <small class="text-muted">@node.NodeId</small>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private IReadOnlyList<NodeResponse>? _nodes;
    private NodeService.NodeSubscription? _subscription;

    protected override async Task OnInitializedAsync()
    {
        // Initial data fetch for pre-rendering or first interactive load
        var nodes = await NodeService.GetNodesAsync();
        UpdateNodesFromResponse(nodes.Select(n => new NodeResponse
        {
            Id = n.Id,
            NodeId = n.NodeId,
            Name = n.Name,
            Address = n.Address,
            Number = n.Number
        }));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Subscribe only once the component is interactive
            _subscription = await NodeService.SubscribeAsync(OnNodesUpdated);

            // Refresh nodes to ensure we have the latest state and haven't missed any updates
            // between OnInitialized and the subscription start.
            var latest = await _subscription.GetCurrentNodesAsync();
            UpdateNodes(latest);
            StateHasChanged();
        }
    }

    private Task OnNodesUpdated(IReadOnlyList<NodeResponse> nodes)
    {
        return InvokeAsync(() =>
        {
            UpdateNodesFromResponse(nodes);
            StateHasChanged();
        });
    }

    private void UpdateNodesFromResponse(IEnumerable<NodeResponse> nodes)
    {
        // Map from Response DTO back to Entity for display if needed,
        // or just use Response DTO in the UI (better)
        _nodes = [..nodes.OrderBy(n => n.Number)];
    }

    private void UpdateNodes(IEnumerable<NodeResponse> nodes)
    {
        UpdateNodesFromResponse(nodes);
    }

    public void Dispose()
    {
        _subscription?.Dispose();
    }
}
